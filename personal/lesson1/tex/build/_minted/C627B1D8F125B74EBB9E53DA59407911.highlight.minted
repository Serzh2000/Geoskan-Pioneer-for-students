    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{save\PYGZus{}kml}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{filename}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Simple KML export for Google Earth.}
\PYG{l+s+sd}{        Note: This uses a rough approximation for meters to degrees (1 deg lat \PYGZti{} 111km).}
\PYG{l+s+sd}{        For production, use a proper geodetic library like \PYGZsq{}pyproj\PYGZsq{}.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{kml\PYGZus{}header} \PYG{o}{=} \PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}\PYG{l+s+s2}{\PYGZlt{}?xml version=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{1.0}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{ encoding=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{UTF\PYGZhy{}8}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{?\PYGZgt{}}
