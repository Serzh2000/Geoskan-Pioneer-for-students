\PYG{l+s+sd}{        Exports the map as a high\PYGZhy{}resolution PNG grid (Clever 4 style).}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{cv2}
        \PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{cv2}\PYG{n+nn}{.}\PYG{n+nn}{aruco}\PYG{+w}{ }\PYG{k}{as}\PYG{+w}{ }\PYG{n+nn}{aruco}
        
