        \PYG{n}{img\PYGZus{}h} \PYG{o}{=} \PYG{n+nb}{int}\PYG{p}{(}\PYG{n}{height\PYGZus{}m} \PYG{o}{*} \PYG{n}{scale}\PYG{p}{)}
        \PYG{n}{img\PYGZus{}w} \PYG{o}{=} \PYG{n+nb}{int}\PYG{p}{(}\PYG{n}{width\PYGZus{}m} \PYG{o}{*} \PYG{n}{scale}\PYG{p}{)}
        \PYG{n}{image} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{ones}\PYG{p}{(}\PYG{p}{(}\PYG{n}{img\PYGZus{}h}\PYG{p}{,} \PYG{n}{img\PYGZus{}w}\PYG{p}{)}\PYG{p}{,} \PYG{n}{dtype}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{uint8}\PYG{p}{)} \PYG{o}{*} \PYG{l+m+mi}{255}
        
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{Generating PNG map: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{img\PYGZus{}w}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{x}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{img\PYGZus{}h}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ pixels (scale: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{scale}\PYG{l+s+si}{:}\PYG{l+s+s2}{.1f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ px/m)}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
        
        \PYG{c+c1}{\PYGZsh{} Draw markers}
