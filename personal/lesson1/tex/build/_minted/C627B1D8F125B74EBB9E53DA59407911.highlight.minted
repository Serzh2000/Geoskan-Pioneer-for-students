\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{kml\PYGZus{}footer} \PYG{o}{=} \PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}\PYG{l+s+s2}{  \PYGZlt{}/Document\PYGZgt{}}
\PYG{l+s+s2}{\PYGZlt{}/kml\PYGZgt{}}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        
        \PYG{n}{kml\PYGZus{}body} \PYG{o}{=} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{\PYGZdq{}}
        
        \PYG{c+c1}{\PYGZsh{} Approximate conversion (very rough, valid only for small areas)}
        \PYG{n}{lat\PYGZus{}deg\PYGZus{}per\PYGZus{}meter} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{/} \PYG{l+m+mf}{111132.928}
        \PYG{n}{lon\PYGZus{}deg\PYGZus{}per\PYGZus{}meter} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{/} \PYG{p}{(}\PYG{l+m+mf}{111132.928} \PYG{o}{*} \PYG{n}{math}\PYG{o}{.}\PYG{n}{cos}\PYG{p}{(}\PYG{n}{math}\PYG{o}{.}\PYG{n}{radians}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{origin\PYGZus{}lat}\PYG{p}{)}\PYG{p}{)}\PYG{p}{)}

        \PYG{k}{for} \PYG{n}{m} \PYG{o+ow}{in} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{markers}\PYG{p}{:}
            \PYG{c+c1}{\PYGZsh{} Calculate GPS position from local offset}
            \PYG{n}{m\PYGZus{}lat} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{origin\PYGZus{}lat} \PYG{o}{+} \PYG{p}{(}\PYG{n}{m}\PYG{o}{.}\PYG{n}{x} \PYG{o}{*} \PYG{n}{lat\PYGZus{}deg\PYGZus{}per\PYGZus{}meter}\PYG{p}{)}
            \PYG{n}{m\PYGZus{}lon} \PYG{o}{=} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{origin\PYGZus{}lon} \PYG{o}{+} \PYG{p}{(}\PYG{n}{m}\PYG{o}{.}\PYG{n}{y} \PYG{o}{*} \PYG{n}{lon\PYGZus{}deg\PYGZus{}per\PYGZus{}meter}\PYG{p}{)}
            
            \PYG{n}{kml\PYGZus{}body} \PYG{o}{+}\PYG{o}{=} \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+s2}{    \PYGZlt{}Placemark\PYGZgt{}}
\PYG{l+s+s2}{      \PYGZlt{}name\PYGZgt{}Marker }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{id}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/name\PYGZgt{}}
\PYG{l+s+s2}{      \PYGZlt{}description\PYGZgt{}Size: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{size}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{m, Yaw: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{yaw}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/description\PYGZgt{}}
\PYG{l+s+s2}{      \PYGZlt{}Point\PYGZgt{}}
\PYG{l+s+s2}{        \PYGZlt{}coordinates\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m\PYGZus{}lon}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{,}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m\PYGZus{}lat}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{,}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{z}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/coordinates\PYGZgt{}}
\PYG{l+s+s2}{      \PYGZlt{}/Point\PYGZgt{}}
\PYG{l+s+s2}{    \PYGZlt{}/Placemark\PYGZgt{}}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}

        \PYG{k}{with} \PYG{n+nb}{open}\PYG{p}{(}\PYG{n}{filename}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}}\PYG{l+s+s1}{w}\PYG{l+s+s1}{\PYGZsq{}}\PYG{p}{)} \PYG{k}{as} \PYG{n}{f}\PYG{p}{:}
            \PYG{n}{f}\PYG{o}{.}\PYG{n}{write}\PYG{p}{(}\PYG{n}{kml\PYGZus{}header}\PYG{o}{.}\PYG{n}{format}\PYG{p}{(}\PYG{n}{name}\PYG{o}{=}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{name}\PYG{p}{)} \PYG{o}{+} \PYG{n}{kml\PYGZus{}body} \PYG{o}{+} \PYG{n}{kml\PYGZus{}footer}\PYG{p}{)}
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{KML saved to }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{filename}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}

    \PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{save\PYGZus{}xml}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{filename}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{        }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{        Generic XML export.}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{xml\PYGZus{}content} \PYG{o}{=} \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}\PYG{l+s+s2}{\PYGZlt{}?xml version=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{1.0}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{ encoding=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{UTF\PYGZhy{}8}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{?\PYGZgt{}}
\PYG{l+s+s2}{\PYGZlt{}map\PYGZgt{}}
\PYG{l+s+s2}{    \PYGZlt{}name\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{name}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/name\PYGZgt{}}
\PYG{l+s+s2}{    \PYGZlt{}origin\PYGZgt{}}
\PYG{l+s+s2}{        \PYGZlt{}lat\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{origin\PYGZus{}lat}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/lat\PYGZgt{}}
\PYG{l+s+s2}{        \PYGZlt{}lon\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{origin\PYGZus{}lon}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/lon\PYGZgt{}}
\PYG{l+s+s2}{    \PYGZlt{}/origin\PYGZgt{}}
\PYG{l+s+s2}{    \PYGZlt{}markers\PYGZgt{}}
\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{k}{for} \PYG{n}{m} \PYG{o+ow}{in} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{markers}\PYG{p}{:}
            \PYG{n}{xml\PYGZus{}content} \PYG{o}{+}\PYG{o}{=} \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}\PYG{l+s+s2}{        \PYGZlt{}marker id=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{id}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{\PYGZgt{}}
\PYG{l+s+s2}{            \PYGZlt{}size\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{size}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/size\PYGZgt{}}
\PYG{l+s+s2}{            \PYGZlt{}position\PYGZgt{}}
\PYG{l+s+s2}{                \PYGZlt{}x\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{x}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/x\PYGZgt{}}
\PYG{l+s+s2}{                \PYGZlt{}y\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{y}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/y\PYGZgt{}}
\PYG{l+s+s2}{                \PYGZlt{}z\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{z}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/z\PYGZgt{}}
\PYG{l+s+s2}{            \PYGZlt{}/position\PYGZgt{}}
\PYG{l+s+s2}{            \PYGZlt{}orientation\PYGZgt{}}
\PYG{l+s+s2}{                \PYGZlt{}yaw\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{yaw}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/yaw\PYGZgt{}}
\PYG{l+s+s2}{            \PYGZlt{}/orientation\PYGZgt{}}
\PYG{l+s+s2}{            \PYGZlt{}dictionary\PYGZgt{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{m}\PYG{o}{.}\PYG{n}{dictionary}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZlt{}/dictionary\PYGZgt{}}
\PYG{l+s+s2}{        \PYGZlt{}/marker\PYGZgt{}}
\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n}{xml\PYGZus{}content} \PYG{o}{+}\PYG{o}{=} \PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}\PYG{l+s+s2}{    \PYGZlt{}/markers\PYGZgt{}}
\PYG{l+s+s2}{\PYGZlt{}/map\PYGZgt{}}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
        
        \PYG{k}{with} \PYG{n+nb}{open}\PYG{p}{(}\PYG{n}{filename}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}}\PYG{l+s+s1}{w}\PYG{l+s+s1}{\PYGZsq{}}\PYG{p}{)} \PYG{k}{as} \PYG{n}{f}\PYG{p}{:}
            \PYG{n}{f}\PYG{o}{.}\PYG{n}{write}\PYG{p}{(}\PYG{n}{xml\PYGZus{}content}\PYG{p}{)}
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{XML saved to }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{filename}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}

\PYG{k}{if} \PYG{n+nv+vm}{\PYGZus{}\PYGZus{}name\PYGZus{}\PYGZus{}} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{\PYGZus{}\PYGZus{}main\PYGZus{}\PYGZus{}}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{:}
    \PYG{c+c1}{\PYGZsh{} Example: Create a grid map for a flight zone (Clever 4 Style)}
    \PYG{c+c1}{\PYGZsh{} Origin: Let\PYGZsq{}s assume a field coordinate}
    \PYG{n}{my\PYGZus{}map} \PYG{o}{=} \PYG{n}{MarkerMap}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{Clever\PYGZus{}Map\PYGZus{}16x16}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{origin\PYGZus{}gps}\PYG{o}{=}\PYG{p}{(}\PYG{l+m+mf}{59.9343}\PYG{p}{,} \PYG{l+m+mf}{30.3351}\PYG{p}{)}\PYG{p}{)} \PYG{c+c1}{\PYGZsh{} St. Petersburg center approx}

    \PYG{c+c1}{\PYGZsh{} Generate a 16x16 grid with 0.5m spacing, marker size 0.2m}
    \PYG{c+c1}{\PYGZsh{} Dictionary for Clever 4 is usually 4x4\PYGZus{}50 or 6x6\PYGZus{}250 depending on setup. Let\PYGZsq{}s stick to 4x4\PYGZus{}50 as per common educational kits or 6x6\PYGZus{}250 for Pioneer.}
    \PYG{c+c1}{\PYGZsh{} User request mentions \PYGZdq{}0\PYGZhy{}999 for ArUco\PYGZdq{}, which implies larger dictionary. But usually grid maps use a subset.}
    \PYG{c+c1}{\PYGZsh{} Let\PYGZsq{}s use DICT\PYGZus{}4X4\PYGZus{}50 as it is common for small grids, or extend if needed. 16x16 = 256 markers. DICT\PYGZus{}4X4\PYGZus{}50 has only 50 markers!}
    \PYG{c+c1}{\PYGZsh{} We need a larger dictionary. DICT\PYGZus{}6X6\PYGZus{}250 has 250 markers (almost enough, need 256).}
    \PYG{c+c1}{\PYGZsh{} DICT\PYGZus{}5X5\PYGZus{}1000 or DICT\PYGZus{}6X6\PYGZus{}1000 is safer. Pioneer standard is DICT\PYGZus{}6X6\PYGZus{}50 (only 50!).}
    \PYG{c+c1}{\PYGZsh{} If we need 16x16=256 unique markers, we MUST use a larger dictionary.}
    \PYG{c+c1}{\PYGZsh{} Let\PYGZsq{}s use DICT\PYGZus{}6X6\PYGZus{}1000 to be safe and cover 0\PYGZhy{}255 IDs.}
    
    \PYG{n}{my\PYGZus{}map}\PYG{o}{.}\PYG{n}{generate\PYGZus{}grid}\PYG{p}{(}\PYG{n}{rows}\PYG{o}{=}\PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{cols}\PYG{o}{=}\PYG{l+m+mi}{16}\PYG{p}{,} \PYG{n}{step\PYGZus{}x}\PYG{o}{=}\PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{n}{step\PYGZus{}y}\PYG{o}{=}\PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{n}{start\PYGZus{}id}\PYG{o}{=}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{n}{marker\PYGZus{}size}\PYG{o}{=}\PYG{l+m+mf}{0.2}\PYG{p}{,} \PYG{n}{dictionary}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{DICT\PYGZus{}6X6\PYGZus{}1000}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Define a dummy trajectory (square path)}
    \PYG{n}{trajectory} \PYG{o}{=} \PYG{p}{[}
        \PYG{p}{(}\PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{l+m+mf}{1.0}\PYG{p}{)}\PYG{p}{,}
        \PYG{p}{(}\PYG{l+m+mf}{3.5}\PYG{p}{,} \PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{l+m+mf}{1.0}\PYG{p}{)}\PYG{p}{,}
        \PYG{p}{(}\PYG{l+m+mf}{3.5}\PYG{p}{,} \PYG{l+m+mf}{3.5}\PYG{p}{,} \PYG{l+m+mf}{1.0}\PYG{p}{)}\PYG{p}{,}
        \PYG{p}{(}\PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{l+m+mf}{3.5}\PYG{p}{,} \PYG{l+m+mf}{1.0}\PYG{p}{)}\PYG{p}{,}
        \PYG{p}{(}\PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{l+m+mf}{0.5}\PYG{p}{,} \PYG{l+m+mf}{1.0}\PYG{p}{)}
    \PYG{p}{]}

