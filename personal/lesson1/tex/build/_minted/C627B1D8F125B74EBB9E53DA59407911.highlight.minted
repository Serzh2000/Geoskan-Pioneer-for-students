        \PYG{n}{scale} \PYG{o}{=} \PYG{n}{resolution\PYGZus{}px} \PYG{o}{/} \PYG{n+nb}{max}\PYG{p}{(}\PYG{n}{width\PYGZus{}m}\PYG{p}{,} \PYG{n}{height\PYGZus{}m}\PYG{p}{)}
        
