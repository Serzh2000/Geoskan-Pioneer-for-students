        \PYG{n}{plt}\PYG{o}{.}\PYG{n}{figtext}\PYG{p}{(}\PYG{l+m+mf}{0.02}\PYG{p}{,} \PYG{l+m+mf}{0.02}\PYG{p}{,} \PYG{n}{info\PYGZus{}text}\PYG{p}{,} \PYG{n}{fontsize}\PYG{o}{=}\PYG{l+m+mi}{10}\PYG{p}{)}

