        \PYG{n}{min\PYGZus{}x}\PYG{p}{,} \PYG{n}{max\PYGZus{}x} \PYG{o}{=} \PYG{n+nb}{min}\PYG{p}{(}\PYG{n}{xs}\PYG{p}{)}\PYG{p}{,} \PYG{n+nb}{max}\PYG{p}{(}\PYG{n}{xs}\PYG{p}{)}
        \PYG{n}{min\PYGZus{}y}\PYG{p}{,} \PYG{n}{max\PYGZus{}y} \PYG{o}{=} \PYG{n+nb}{min}\PYG{p}{(}\PYG{n}{ys}\PYG{p}{)}\PYG{p}{,} \PYG{n+nb}{max}\PYG{p}{(}\PYG{n}{ys}\PYG{p}{)}
        
        \PYG{c+c1}{\PYGZsh{} Add padding (e.g., 1 meter)}
        \PYG{n}{padding\PYGZus{}m} \PYG{o}{=} \PYG{l+m+mf}{1.0}
        \PYG{n}{width\PYGZus{}m} \PYG{o}{=} \PYG{p}{(}\PYG{n}{max\PYGZus{}x} \PYG{o}{\PYGZhy{}} \PYG{n}{min\PYGZus{}x}\PYG{p}{)} \PYG{o}{+} \PYG{l+m+mi}{2} \PYG{o}{*} \PYG{n}{padding\PYGZus{}m}
        \PYG{n}{height\PYGZus{}m} \PYG{o}{=} \PYG{p}{(}\PYG{n}{max\PYGZus{}y} \PYG{o}{\PYGZhy{}} \PYG{n}{min\PYGZus{}y}\PYG{p}{)} \PYG{o}{+} \PYG{l+m+mi}{2} \PYG{o}{*} \PYG{n}{padding\PYGZus{}m}
        
