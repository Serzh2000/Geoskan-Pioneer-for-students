            \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{destroyAllWindows}\PYG{p}{(}\PYG{p}{)}
            \PYG{k}{return} \PYG{n}{images}
        \PYG{k}{if} \PYG{n}{key} \PYG{o}{==} \PYG{n+nb}{ord}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{1}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}\PYG{p}{:}
            \PYG{n}{images}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{frame}\PYG{p}{)}
            \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{Frame \PYGZsh{}}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{n+nb}{str}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{images}\PYG{p}{)}\PYG{p}{)}\PYG{p}{)}
            \PYG{k}{if} \PYG{n}{save}\PYG{p}{:}
                \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{imwrite}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{frame\PYGZus{}}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{n+nb}{str}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{images}\PYG{p}{)}\PYG{p}{)} \PYG{o}{+} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{.jpg}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{frame}\PYG{p}{)}
            \PYG{n}{time}\PYG{o}{.}\PYG{n}{sleep}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{)}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{calibrate}\PYG{p}{(}\PYG{n}{images}\PYG{p}{)}\PYG{p}{:}
    \PYG{c+c1}{\PYGZsh{} Defining the dimensions of checkerboard}
    \PYG{n}{CHECKERBOARD} \PYG{o}{=} \PYG{p}{(}\PYG{l+m+mi}{6}\PYG{p}{,} \PYG{l+m+mi}{9}\PYG{p}{)}
    \PYG{n}{criteria} \PYG{o}{=} \PYG{p}{(}\PYG{n}{cv2}\PYG{o}{.}\PYG{n}{TERM\PYGZus{}CRITERIA\PYGZus{}EPS} \PYG{o}{+} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{TERM\PYGZus{}CRITERIA\PYGZus{}MAX\PYGZus{}ITER}\PYG{p}{,} \PYG{l+m+mi}{30}\PYG{p}{,} \PYG{l+m+mf}{0.001}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Creating vector to store vectors of 3D points for each checkerboard image}
    \PYG{n}{objpoints} \PYG{o}{=} \PYG{p}{[}\PYG{p}{]}
    \PYG{c+c1}{\PYGZsh{} Creating vector to store vectors of 2D points for each checkerboard image}
    \PYG{n}{imgpoints} \PYG{o}{=} \PYG{p}{[}\PYG{p}{]}

    \PYG{c+c1}{\PYGZsh{} Defining the world coordinates for 3D points}
    \PYG{n}{objp} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{zeros}\PYG{p}{(}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{CHECKERBOARD}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]} \PYG{o}{*} \PYG{n}{CHECKERBOARD}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{p}{,} \PYG{l+m+mi}{3}\PYG{p}{)}\PYG{p}{,} \PYG{n}{np}\PYG{o}{.}\PYG{n}{float32}\PYG{p}{)}
    \PYG{n}{objp}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{p}{:}\PYG{p}{,} \PYG{p}{:}\PYG{l+m+mi}{2}\PYG{p}{]} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{mgrid}\PYG{p}{[}\PYG{l+m+mi}{0} \PYG{p}{:} \PYG{n}{CHECKERBOARD}\PYG{p}{[}\PYG{l+m+mi}{0}\PYG{p}{]}\PYG{p}{,} \PYG{l+m+mi}{0} \PYG{p}{:} \PYG{n}{CHECKERBOARD}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{p}{]}\PYG{o}{.}\PYG{n}{T}\PYG{o}{.}\PYG{n}{reshape}\PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{l+m+mi}{2}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Extracting path of individual image stored in a given directory}
    \PYG{k}{for} \PYG{n}{img} \PYG{o+ow}{in} \PYG{n}{images}\PYG{p}{:}
        \PYG{n}{gray} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{cvtColor}\PYG{p}{(}\PYG{n}{img}\PYG{p}{,} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{COLOR\PYGZus{}BGR2GRAY}\PYG{p}{)}
        \PYG{c+c1}{\PYGZsh{} Find the chess board corners}
        \PYG{c+c1}{\PYGZsh{} If desired number of corners are found in the image then ret = true}
        \PYG{n}{ret}\PYG{p}{,} \PYG{n}{corners} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{findChessboardCorners}\PYG{p}{(}
            \PYG{n}{gray}\PYG{p}{,}
            \PYG{n}{CHECKERBOARD}\PYG{p}{,}
            \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{CALIB\PYGZus{}CB\PYGZus{}ADAPTIVE\PYGZus{}THRESH}
            \PYG{o}{+} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{CALIB\PYGZus{}CB\PYGZus{}FAST\PYGZus{}CHECK}
            \PYG{o}{+} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{CALIB\PYGZus{}CB\PYGZus{}NORMALIZE\PYGZus{}IMAGE}\PYG{p}{,}
        \PYG{p}{)}

        \PYG{k}{if} \PYG{n}{ret} \PYG{o}{==} \PYG{k+kc}{True}\PYG{p}{:}
            \PYG{n}{objpoints}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{objp}\PYG{p}{)}
            \PYG{c+c1}{\PYGZsh{} refining pixel coordinates for given 2d points.}
            \PYG{n}{corners2} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{cornerSubPix}\PYG{p}{(}\PYG{n}{gray}\PYG{p}{,} \PYG{n}{corners}\PYG{p}{,} \PYG{p}{(}\PYG{l+m+mi}{11}\PYG{p}{,} \PYG{l+m+mi}{11}\PYG{p}{)}\PYG{p}{,} \PYG{p}{(}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{p}{,} \PYG{n}{criteria}\PYG{p}{)}

            \PYG{n}{imgpoints}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{corners2}\PYG{p}{)}

            \PYG{c+c1}{\PYGZsh{} Draw and display the corners}
            \PYG{n}{img} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{drawChessboardCorners}\PYG{p}{(}\PYG{n}{img}\PYG{p}{,} \PYG{n}{CHECKERBOARD}\PYG{p}{,} \PYG{n}{corners2}\PYG{p}{,} \PYG{n}{ret}\PYG{p}{)}

        \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{imshow}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{img}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{img}\PYG{p}{)}
        \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{waitKey}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{)}

    \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{destroyAllWindows}\PYG{p}{(}\PYG{p}{)}

    \PYG{n}{ret}\PYG{p}{,} \PYG{n}{mtx}\PYG{p}{,} \PYG{n}{dist}\PYG{p}{,} \PYG{n}{rvecs}\PYG{p}{,} \PYG{n}{tvecs} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{calibrateCamera}\PYG{p}{(}
        \PYG{n}{objpoints}\PYG{p}{,} \PYG{n}{imgpoints}\PYG{p}{,} \PYG{n}{gray}\PYG{o}{.}\PYG{n}{shape}\PYG{p}{[}\PYG{p}{:}\PYG{p}{:}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{p}{,} \PYG{k+kc}{None}\PYG{p}{,} \PYG{k+kc}{None}
    \PYG{p}{)}

    \PYG{k}{return} \PYG{n}{mtx}\PYG{p}{,} \PYG{n}{dist}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{save\PYGZus{}coefficients}\PYG{p}{(}\PYG{n}{mtx}\PYG{p}{,} \PYG{n}{dist}\PYG{p}{,} \PYG{n}{path}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Save the camera matrix and the distortion coefficients to given path/file.\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{cv\PYGZus{}file} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{FileStorage}\PYG{p}{(}\PYG{n}{path}\PYG{p}{,} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{FILE\PYGZus{}STORAGE\PYGZus{}WRITE}\PYG{p}{)}
    \PYG{n}{cv\PYGZus{}file}\PYG{o}{.}\PYG{n}{write}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{mtx}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{mtx}\PYG{p}{)}
    \PYG{n}{cv\PYGZus{}file}\PYG{o}{.}\PYG{n}{write}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{dist}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{dist}\PYG{p}{)}
    \PYG{c+c1}{\PYGZsh{} note you *release* you don\PYGZsq{}t close() a FileStorage object}
    \PYG{n}{cv\PYGZus{}file}\PYG{o}{.}\PYG{n}{release}\PYG{p}{(}\PYG{p}{)}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{load\PYGZus{}coefficients}\PYG{p}{(}\PYG{n}{path}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Loads camera matrix and distortion coefficients.\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{c+c1}{\PYGZsh{} FILE\PYGZus{}STORAGE\PYGZus{}READ}
    \PYG{n}{cv\PYGZus{}file} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{FileStorage}\PYG{p}{(}\PYG{n}{path}\PYG{p}{,} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{FILE\PYGZus{}STORAGE\PYGZus{}READ}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} note we also have to specify the type to retrieve other wise we only get a}
    \PYG{c+c1}{\PYGZsh{} FileNode object back instead of a matrix}
    \PYG{n}{camera\PYGZus{}matrix} \PYG{o}{=} \PYG{n}{cv\PYGZus{}file}\PYG{o}{.}\PYG{n}{getNode}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{mtx}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}\PYG{o}{.}\PYG{n}{mat}\PYG{p}{(}\PYG{p}{)}
    \PYG{n}{dist\PYGZus{}coeffs} \PYG{o}{=} \PYG{n}{cv\PYGZus{}file}\PYG{o}{.}\PYG{n}{getNode}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{dist}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}\PYG{o}{.}\PYG{n}{mat}\PYG{p}{(}\PYG{p}{)}

    \PYG{n}{cv\PYGZus{}file}\PYG{o}{.}\PYG{n}{release}\PYG{p}{(}\PYG{p}{)}
    \PYG{k}{return} \PYG{n}{camera\PYGZus{}matrix}\PYG{p}{,} \PYG{n}{dist\PYGZus{}coeffs}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{main}\PYG{p}{(}\PYG{p}{)}\PYG{p}{:}
