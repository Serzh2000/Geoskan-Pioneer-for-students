\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Retreive images from a directory using a provided path (`folder\PYGZus{}name`)}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{images\PYGZus{}list} \PYG{o}{=} \PYG{n}{glob}\PYG{o}{.}\PYG{n}{glob}\PYG{p}{(}\PYG{n}{folder\PYGZus{}name} \PYG{o}{+} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{/}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{n}{file\PYGZus{}type}\PYG{p}{)}
    \PYG{n}{images} \PYG{o}{=} \PYG{p}{[}\PYG{p}{]}
    \PYG{k}{for} \PYG{n}{fname} \PYG{o+ow}{in} \PYG{n}{images\PYGZus{}list}\PYG{p}{:}
        \PYG{n}{img} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{imread}\PYG{p}{(}\PYG{n}{fname}\PYG{p}{)}
        \PYG{n}{images}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{img}\PYG{p}{)}
    \PYG{k}{return} \PYG{n}{images}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{get\PYGZus{}images\PYGZus{}from\PYGZus{}drone\PYGZus{}camera}\PYG{p}{(}\PYG{n}{camera}\PYG{p}{,} \PYG{n}{save}\PYG{o}{=}\PYG{k+kc}{False}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Retreive images from a drone\PYGZsq{}s camera}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{images} \PYG{o}{=} \PYG{p}{[}\PYG{p}{]}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{Press }\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{1}\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{ to take frame}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{Press ESC or }\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{q}\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{ to finish}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{k}{while} \PYG{k+kc}{True}\PYG{p}{:}
        \PYG{n}{frame} \PYG{o}{=} \PYG{n}{camera}\PYG{o}{.}\PYG{n}{get\PYGZus{}cv\PYGZus{}frame}\PYG{p}{(}\PYG{p}{)}
        \PYG{k}{if} \PYG{n}{frame} \PYG{o+ow}{is} \PYG{o+ow}{not} \PYG{k+kc}{None}\PYG{p}{:}
            \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{imshow}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{frames}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{frame}\PYG{p}{)}

            \PYG{n}{key} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{waitKey}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{)}
            \PYG{k}{if} \PYG{n}{key} \PYG{o}{==} \PYG{l+m+mi}{27} \PYG{o+ow}{or} \PYG{n}{key} \PYG{o}{==} \PYG{n+nb}{ord}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{q}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}\PYG{p}{:}
                \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{destroyAllWindows}\PYG{p}{(}\PYG{p}{)}
                \PYG{k}{return} \PYG{n}{images}
            \PYG{k}{if} \PYG{n}{key} \PYG{o}{==} \PYG{n+nb}{ord}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{1}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}\PYG{p}{:}
                \PYG{n}{images}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{frame}\PYG{p}{)}
                \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{Frame \PYGZsh{}}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{n+nb}{str}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{images}\PYG{p}{)}\PYG{p}{)}\PYG{p}{)}
                \PYG{k}{if} \PYG{n}{save}\PYG{p}{:}
                    \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{imwrite}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{frame\PYGZus{}}\PYG{l+s+s2}{\PYGZdq{}} \PYG{o}{+} \PYG{n+nb}{str}\PYG{p}{(}\PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{images}\PYG{p}{)}\PYG{p}{)} \PYG{o}{+} \PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{.jpg}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{frame}\PYG{p}{)}
                \PYG{n}{time}\PYG{o}{.}\PYG{n}{sleep}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{)}


\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{get\PYGZus{}images\PYGZus{}from\PYGZus{}computer\PYGZus{}camera}\PYG{p}{(}\PYG{n}{capture}\PYG{p}{,} \PYG{n}{save}\PYG{o}{=}\PYG{k+kc}{False}\PYG{p}{)}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Retreive images using the PC\PYGZsq{}s camera device}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{images} \PYG{o}{=} \PYG{p}{[}\PYG{p}{]}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{Press }\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{1}\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{ to take frame}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{Press ESC or }\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{q}\PYG{l+s+s2}{\PYGZsq{}}\PYG{l+s+s2}{ to finish}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{)}
    \PYG{k}{while} \PYG{k+kc}{True}\PYG{p}{:}
        \PYG{n}{ret}\PYG{p}{,} \PYG{n}{frame} \PYG{o}{=} \PYG{n}{capture}\PYG{o}{.}\PYG{n}{read}\PYG{p}{(}\PYG{p}{)}
        \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{imshow}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{frames}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{,} \PYG{n}{frame}\PYG{p}{)}

        \PYG{n}{key} \PYG{o}{=} \PYG{n}{cv2}\PYG{o}{.}\PYG{n}{waitKey}\PYG{p}{(}\PYG{l+m+mi}{1}\PYG{p}{)}
