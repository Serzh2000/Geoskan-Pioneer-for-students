\PYG{+w}{  }\PYG{n+nv}{x}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nv}{x}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{l+m+mi}{1}
\PYG{k+kr}{end}
\PYG{c+c1}{\PYGZhy{}\PYGZhy{} уменьшаем x до 0 минимум один раз}
\PYG{k+kr}{repeat}
\PYG{+w}{  }\PYG{n+nv}{x}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nv}{x}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{+w}{ }\PYG{l+m+mi}{1}
\PYG{k+kr}{until}\PYG{+w}{ }\PYG{n+nv}{x}\PYG{+w}{ }\PYG{o}{==}\PYG{+w}{ }\PYG{l+m+mi}{0}
