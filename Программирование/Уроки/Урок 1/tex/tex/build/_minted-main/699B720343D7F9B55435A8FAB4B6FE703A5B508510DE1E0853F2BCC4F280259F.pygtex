\PYG{+w}{        }\PYG{n+nv}{leds}\PYG{p}{:}\PYG{n+nf}{set}\PYG{p}{(}\PYG{n+nv}{i}\PYG{p}{,}\PYG{+w}{ }\PYG{n+nf}{unpack}\PYG{p}{(}\PYG{n+nv}{col}\PYG{p}{))}
\PYG{+w}{    }\PYG{k+kr}{end}
\PYG{k+kr}{end}

\PYG{c+c1}{\PYGZhy{}\PYGZhy{} Функция, реализующая выключение таймера и изменение цвета светодиодов на красный}
\PYG{k+kd}{local}\PYG{+w}{ }\PYG{k+kr}{function}\PYG{+w}{ }\PYG{n+nf}{emergency}\PYG{p}{()}
