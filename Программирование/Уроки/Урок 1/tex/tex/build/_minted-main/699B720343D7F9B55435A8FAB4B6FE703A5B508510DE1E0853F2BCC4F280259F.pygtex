\PYG{k+kd}{local}\PYG{+w}{ }\PYG{n+nv}{leds}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nv}{Ledbar}\PYG{p}{.}\PYG{n+nf}{new}\PYG{p}{(}\PYG{n+nv}{ledNumber}\PYG{p}{)}

\PYG{c+c1}{\PYGZhy{}\PYGZhy{} Функция, изменяющая цвет 4\PYGZhy{}х RGB светодиодов на базовой плате}
