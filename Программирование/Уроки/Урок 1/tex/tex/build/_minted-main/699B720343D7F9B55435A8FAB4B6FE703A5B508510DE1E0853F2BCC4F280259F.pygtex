\PYG{+w}{    }\PYG{k+kr}{end}
\PYG{k+kr}{end}

\PYG{n+nv}{color}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{\PYGZob{}}\PYG{l+m+mi}{0}\PYG{p}{,}\PYG{+w}{ }\PYG{l+m+mi}{0}\PYG{p}{,}\PYG{+w}{ }\PYG{l+m+mi}{0}\PYG{p}{\PYGZcb{}}
\PYG{n+nv}{step}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mf}{0.05}
\PYG{n+nv}{index}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{1}

\PYG{c+c1}{\PYGZhy{}\PYGZhy{} Создание таймера, каждую секунду меняющего цвета каждого из 4\PYGZhy{}х светодиодов на случайные}
\PYG{n+nv}{timerRandomLED}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nv}{Timer}\PYG{p}{.}\PYG{n+nf}{new}\PYG{p}{(}\PYG{l+m+mf}{0.05}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kr}{function}\PYG{+w}{ }\PYG{p}{()}
\PYG{+w}{    }\PYG{n+nv}{color}\PYG{p}{[}\PYG{n+nv}{index}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nv}{color}\PYG{p}{[}\PYG{n+nv}{index}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n+nv}{step}
\PYG{+w}{    }\PYG{k+kr}{if}\PYG{+w}{ }\PYG{n+nv}{color}\PYG{p}{[}\PYG{n+nv}{index}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{\PYGZgt{}}\PYG{+w}{ }\PYG{l+m+mf}{0.95}\PYG{+w}{ }\PYG{o+ow}{or}\PYG{+w}{ }\PYG{n+nv}{color}\PYG{p}{[}\PYG{n+nv}{index}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{+w}{ }\PYG{l+m+mf}{0.05}\PYG{+w}{ }\PYG{k+kr}{then}
\PYG{+w}{        }\PYG{k+kr}{if}\PYG{+w}{ }\PYG{n+nv}{index}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{+w}{ }\PYG{l+m+mi}{3}\PYG{+w}{ }\PYG{k+kr}{then}
\PYG{+w}{            }\PYG{n+nv}{index}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nv}{index}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{l+m+mi}{1}
\PYG{+w}{        }\PYG{k+kr}{else}
\PYG{+w}{            }\PYG{n+nv}{index}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{1}
\PYG{+w}{            }\PYG{n+nv}{step}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{n+nv}{step}
\PYG{+w}{        }\PYG{k+kr}{end}
\PYG{+w}{    }\PYG{k+kr}{end}
\PYG{+w}{    }\PYG{n+nf}{changeColor}\PYG{p}{(}\PYG{n+nv}{color}\PYG{p}{)}
\PYG{k+kr}{end}\PYG{p}{)}
